# Required for Coolify HTTP healthcheck and OpenAI-compatible API access.
# Generate with: openssl rand -hex 32
API_SERVER_KEY=

# API server. Required when Coolify, dashboard, or external clients need HTTP.
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_CORS_ORIGINS=

# Dashboard. Disabled in v1; expose only after adding OAuth or another auth layer.
HERMES_DASHBOARD=0
HERMES_DASHBOARD_HOST=127.0.0.1
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_INSECURE=
HERMES_DASHBOARD_OAUTH_CLIENT_ID=

# Container user. Leave defaults for named Coolify volumes.
HERMES_UID=10000
HERMES_GID=10000

# Recommended provider for v1. Alternatively, run `hermes setup --portal`
# once inside the container after first deploy.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_FOUNDRY_BASE_URL=
AZURE_FOUNDRY_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
NOVITA_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
HF_TOKEN=

# Messaging gateway. Set only the platforms you will use.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=
GATEWAY_ALLOWED_USERS=
GATEWAY_ALLOW_ALL_USERS=false

# Optional tool providers.
EXA_API_KEY=
FIRECRAWL_API_KEY=
FAL_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
HONCHO_API_KEY=

# ContentHub VcM Convex integration.
CONTENTHUB_CONVEX_SITE_URL=https://careful-monitor-525.convex.site
CONTENTHUB_CONVEX_API_KEY=
